{
  "name": "whatflow-inbox",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace @whatflow/api\" \"npm run dev --workspace @whatflow/web\"",
    "build": "npm run build --workspace @whatflow/api && npm run build --workspace @whatflow/web",
    "start": "npm run start --workspace @whatflow/api",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "concurrently": "^9.2.1",
    "prisma": "^6.6.0"
  }
}
