generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum InboxConnectionType {
  embedded
  manual
}

enum InboxStatus {
  draft
  connected
}

enum ConversationStatus {
  open
  resolved
}

enum MessageDirection {
  incoming
  outgoing
  status
}

enum AgentRole {
  admin
  manager
  agent
}

model AdminMetaAppConfig {
  id                    String   @id @default("singleton")
  embeddedSignupEnabled Boolean  @default(false)
  appId                 String   @default("")
  appSecret             String   @default("")
  configurationId       String   @default("")
  verifyToken           String   @default("")
  systemUserAccessToken String   @default("")
  graphBaseUrl          String   @default("https://graph.facebook.com")
  graphVersion          String   @default("v23.0")
  webhookCallbackUrl    String   @default("")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model GlobalMetaConfig {
  id           String   @id @default("singleton")
  accessToken  String   @default("")
  verifyToken  String   @default("")
  graphBaseUrl String   @default("https://graph.facebook.com")
  graphVersion String   @default("v23.0")
  wabaId       String   @default("")
  phoneNumberId String  @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Account {
  id        String        @id @default(cuid())
  name      String
  slug      String        @unique
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  agents    Agent[]
  inboxes   Inbox[]
}

model Agent {
  id         String    @id @default(cuid())
  accountId  String
  name       String
  email      String
  role       AgentRole @default(agent)
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  account    Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, email])
}

model Inbox {
  id                String               @id @default(cuid())
  accountId         String
  name              String
  connectionType    InboxConnectionType
  status            InboxStatus          @default(draft)
  phoneNumber       String               @default("")
  phoneNumberId     String               @default("")
  businessAccountId String               @default("")
  accessToken       String               @default("")
  verifyToken       String               @default("")
  metaAppId         String               @default("")
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  account           Account              @relation(fields: [accountId], references: [id], onDelete: Cascade)
  conversations     Conversation[]

  @@index([accountId])
}

model Contact {
  id          String         @id @default(cuid())
  waId        String         @unique
  name        String
  profileName String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  conversations Conversation[]
}

model Conversation {
  id                 String              @id @default(cuid())
  inboxId            String
  waId               String
  title              String
  phoneNumberId      String?
  lastMessageAt      DateTime            @default(now())
  lastMessagePreview String              @default("")
  unreadCount        Int                 @default(0)
  contactId          String
  status             ConversationStatus  @default(open)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  inbox              Inbox               @relation(fields: [inboxId], references: [id], onDelete: Cascade)
  contact            Contact             @relation(fields: [contactId], references: [id], onDelete: Cascade)
  messages           Message[]

  @@index([inboxId])
}

model Message {
  id             String            @id
  conversationId String
  waId           String
  inboxId        String
  type           String
  direction      MessageDirection
  text           String?
  rawJson        Json?
  timestamp      DateTime
  status         String?
  createdAt      DateTime          @default(now())
  conversation   Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([inboxId])
}
